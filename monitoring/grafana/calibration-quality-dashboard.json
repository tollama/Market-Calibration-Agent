{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Calibration quality monitoring: Brier, ECE, conformal coverage, drift status, low-confidence markets",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Calibration Score Trends",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "calibration_brier_score",
          "legendFormat": "Brier Score",
          "refId": "A"
        },
        {
          "expr": "calibration_ece",
          "legendFormat": "ECE",
          "refId": "B"
        },
        {
          "expr": "calibration_log_loss",
          "legendFormat": "Log Loss",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.15 },
              { "color": "red", "value": 0.25 }
            ]
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Conformal Coverage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "calibration_conformal_coverage",
          "legendFormat": "Coverage",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.65 },
              { "color": "green", "value": 0.75 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Target (0.80)" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Conformal Width Scale",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "calibration_conformal_width",
          "legendFormat": "Width Scale",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.3 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "title": "Drift Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "calibration_drift_detected",
          "legendFormat": "Drift Detected",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Stable", "color": "green" } }, "type": "value" },
            { "options": { "1": { "text": "DRIFT", "color": "red" } }, "type": "value" }
          ]
        }
      },
      "options": {
        "colorMode": "background",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Brier Score (Current)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 18, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "calibration_brier_score",
          "legendFormat": "Brier",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.15 },
              { "color": "red", "value": 0.25 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "ECE (Current)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 3, "x": 21, "y": 8 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "calibration_ece",
          "legendFormat": "ECE",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 4,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.08 },
              { "color": "red", "value": 0.10 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Market Counts",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "calibration_total_markets",
          "legendFormat": "Total Markets",
          "refId": "A"
        },
        {
          "expr": "calibration_low_confidence_markets",
          "legendFormat": "Low Confidence Markets",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Low Confidence Markets" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Low Confidence Market Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "calibration_low_confidence_markets / clamp_min(calibration_total_markets, 1)",
          "legendFormat": "Low Confidence Ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "decimals": 1,
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.3 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "title": "Base Rate Swing (from Drift Analysis)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 16 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "calibration_drift_detected",
          "legendFormat": "Drift Flag (0/1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 1,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 30,
            "drawStyle": "bars"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Drift Flag (0/1)" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }
            ]
          }
        ]
      }
    },
    {
      "title": "Route Share",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (route_selected) (rate(tsfm_route_selected_total[$__rate_interval]))",
          "legendFormat": "{{route_selected}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 12
          }
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Fallback Reasons",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (reason) (rate(tsfm_fallback_total[$__rate_interval]))",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "title": "Route Decision Mix",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum by (route_reason) (increase(tsfm_route_selected_total[$__range]))",
          "legendFormat": "{{route_reason}}",
          "refId": "A"
        }
      ],
      "options": {
        "legend": { "displayMode": "list", "placement": "right" },
        "tooltip": { "mode": "single" }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 30,
  "style": "dark",
  "tags": ["calibration", "quality", "ml-platform"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Calibration Quality",
  "uid": "calibration-quality",
  "version": 2
}
